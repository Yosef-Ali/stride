# prevent EAS from hoisting monorepo workspace deps
../node_modules
../package.json
../package-lock.json
../pnpm-lock.yaml
../pnpm-workspace.yaml
../packages
../api
../.vercel
../dist
../.next

# local exclusions
node_modules
.expo
dist
.git
*.jks
*.keystore

# android build intermediates (EAS does its own build)
android/app/build
android/.gradle
android/build
android/local.properties
